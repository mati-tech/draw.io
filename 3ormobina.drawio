<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="7UvmsAAiFPRtS6VgAfee">
    <mxGraphModel dx="967" dy="840" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; Быстрая сортировка Хоара\n&#39; Блок-схема алгоритма\n\ntitle Блок-схема быстрой сортировки (Хоара)\n\nstart\n\n:Вход: массив arr[], индексы low, high;\n\nif (low &lt; high?) then (Да)\n  :Выбор опорного элемента:\n  **pivot = arr[(low+high)/2]**;\n  :i = low;\n  :j = high;\n  \n  while (i &lt;= j?) is (Да)\n    \n    while (arr[i] &lt; pivot?) is (Да)\n      :i++;\n      :Cn++ (сравнение);\n    endwhile (Нет)\n    \n    while (arr[j] &gt; pivot?) is (Да)\n      :j--;\n      :Cn++ (сравнение);\n    endwhile (Нет)\n    \n    if (i &lt;= j?) then (Да)\n      :swap(arr[i], arr[j]);\n      :i++;\n      :j--;\n      :Mn += 2 (перемещения);\n    endif\n    \n  endwhile (Нет)\n  \n  :pi = i;\n  \n  :Рекурсивный вызов:\n  quickSort(arr, low, pi-1);\n  \n  :Рекурсивный вызов:\n  quickSort(arr, pi, high);\n  \nelse (Нет)\n  :Базовый случай: возврат;\nendif\n\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="28a_ynRlmQEmoT2sj-Xy-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1374" width="415" x="40" y="20" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; Сортировка Шелла со смещениями Седжвика\n&#39; Блок-схема алгоритма\n\ntitle Блок-схема ускоренной сортировки (Шелл + смещения Седжвика)\n\nstart\n\n:Ввод массива arr[] и его размера n;\n\n:Генерация смещений по формулам Седжвика:\n---\n**i = 0**\n**Пока 3*d[i] &lt;= n:**\n  - Если i чётный:\n    d = 9*2^i - 9*2^(i/2) + 1\n  - Если i нечётный:\n    d = 8*2^i - 6*2^((i+1)/2) + 1\n  - Добавить d в массив gaps\n  - i++\n**Развернуть gaps в обратном порядке**\n---;\n\n:Установить первый gap из gaps\n(от наибольшего к 1);\n\nwhile (Есть следующий gap?) is (Да)\n  :Взять текущий gap;\n\n  :i = gap;\n  \n  while (i &lt; n?) is (Да)\n    :temp = arr[i];\n    :j = i;\n    \n    while (j &gt;= gap и arr[j-gap] &gt; temp?) is (Да)\n      :arr[j] = arr[j-gap];\n      :j = j - gap;\n      :Cn++ (сравнение);\n      :Mn++ (перемещение);\n    endwhile (Нет)\n    \n    :arr[j] = temp;\n    :Mn++ (перемещение);\n    \n    :i++;\n  endwhile (Нет)\n  \n  :Перейти к следующему gap;\nendwhile (Нет)\n\n:Массив отсортирован;\n\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="28a_ynRlmQEmoT2sj-Xy-5">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1367" width="456" x="250" y="1420" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
